{
    "$schema": "https://www.schemastore.org/package.json",
    "version": "2.8.3",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "test": "LARAVEL_BYPASS_ENV_CHECK=1 vitest run --coverage",
        "lint": "eslint resources/js",
        "lint:fix": "eslint resources/js --fix",
        "format": "docker-compose exec app ./vendor/bin/pint",
        "phpstan": "docker-compose exec app ./vendor/bin/phpstan analyze app --level=8 --memory-limit=-1",
        "test:e2e": "npx playwright test --reporter=list",
        "test:e2e:ui": "npx playwright test --ui",
        "test:e2e:report": "npx playwright show-report"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@playwright/test": "^1.61.1",
        "@tailwindcss/vite": "^4.0.0",
        "@vitejs/plugin-vue": "^6.0.7",
        "@vitest/coverage-v8": "^4.1.8",
        "@vue/test-utils": "^2.4.10",
        "concurrently": "^10.0.3",
        "eslint": "^10.4.1",
        "eslint-plugin-vue": "^10.9.2",
        "globals": "^17.6.0",
        "jsdom": "^29.1.1",
        "laravel-vite-plugin": "^3.1",
        "tailwindcss": "^4.0.0",
        "vite": "^8.0.16",
        "vite-plugin-pwa": "^1.3.0",
        "vitest": "^4.1.7"
    },
    "dependencies": {
        "axios": "^1.16.1",
        "pinia": "^3.0.4",
        "vue": "^3.5.34",
        "vue-i18n": "^9.14.5",
        "vue-router": "^4.6.4"
    }
}
